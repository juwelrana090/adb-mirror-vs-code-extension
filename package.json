{
  "name": "adb-mirror",
  "displayName": "ADB Mirror",
  "description": "Mirror Android devices directly in VS Code using scrcpy",
  "version": "1.0.0",
  "publisher": "your-publisher-name",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "ADB Mirror",
      "properties": {
        "adbMirror.scrcpyPath": {
          "type": "string",
          "default": "",
          "description": "Optional absolute path to the scrcpy executable. Leave empty to auto-detect from PATH/common install locations."
        },
        "adbMirror.adbFrameIntervalMs": {
          "type": "number",
          "default": 80,
          "minimum": 20,
          "maximum": 500,
          "description": "ADB screenshot fallback frame interval in milliseconds. Lower is faster but uses more CPU."
        },
        "adbMirror.scrcpyMaxSize": {
          "type": "number",
          "default": 720,
          "minimum": 360,
          "maximum": 1600,
          "description": "Maximum video size passed to scrcpy. Lower values usually improve speed and reduce latency."
        },
        "adbMirror.scrcpyMaxFps": {
          "type": "number",
          "default": 60,
          "minimum": 15,
          "maximum": 120,
          "description": "Maximum frame rate requested from scrcpy."
        },
        "adbMirror.scrcpyVideoBitRate": {
          "type": "string",
          "default": "8M",
          "description": "Video bitrate passed to scrcpy (for example: 4M, 8M, 12M)."
        }
      }
    },
    "commands": [
      {
        "command": "adbMirror.refreshDevices",
        "title": "Refresh Devices",
        "icon": "$(refresh)"
      },
      {
        "command": "adbMirror.startMirror",
        "title": "Start Mirror",
        "icon": "$(play)"
      },
      {
        "command": "adbMirror.stopMirror",
        "title": "Stop Mirror",
        "icon": "$(stop)"
      },
      {
        "command": "adbMirror.sendHome",
        "title": "Home",
        "icon": "$(home)"
      },
      {
        "command": "adbMirror.sendBack",
        "title": "Back",
        "icon": "$(arrow-left)"
      },
      {
        "command": "adbMirror.sendVolumeUp",
        "title": "Volume Up",
        "icon": "$(chevron-up)"
      },
      {
        "command": "adbMirror.sendVolumeDown",
        "title": "Volume Down",
        "icon": "$(chevron-down)"
      },
      {
        "command": "adbMirror.sendPower",
        "title": "Power",
        "icon": "$(lightbulb)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "adbMirrorContainer",
          "title": "ADB Mirror",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "adbMirrorContainer": [
        {
          "id": "adbMirrorDevices",
          "name": "Devices",
          "icon": "$(device-mobile)"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "adbMirror.refreshDevices",
          "icon": "$(refresh)",
          "when": "view == adbMirrorDevices",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "adbMirror.startMirror",
          "icon": "$(play)",
          "when": "view == adbMirrorDevices && viewItem == device",
          "group": "inline"
        },
        {
          "command": "adbMirror.stopMirror",
          "icon": "$(stop)",
          "when": "view == adbMirrorDevices && viewItem == device",
          "group": "inline"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.80.0",
    "@typescript-eslint/eslint-plugin": "^5.59.0",
    "@typescript-eslint/parser": "^5.59.0",
    "eslint": "^8.41.0",
    "typescript": "^5.0.4"
  }
}